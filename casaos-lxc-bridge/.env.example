# casaos-lxc-bridge — Konfiguration
# Kopieren als .env und Werte eintragen

# Proxmox VE
PROXMOX_HOST=https://192.168.10.147:8006
PROXMOX_TOKEN=PVEAPIToken=casaos@pve!casaos-bridge-token=<UUID-HIER>
PROXMOX_NODE=pve
PROXMOX_TEMPLATE_ID=9000
PROXMOX_STORAGE=local-lvm

# CasaOS Dashboard
CASAOS_API_URL=http://192.168.10.141/v2/apps
CASAOS_API_TOKEN=

# App-Stores
# Umbrel offizieller Store (200+ Apps) — true/false
UMBREL_STORE_ENABLED=true

# Custom Stores: Typ-Präfix + Raw-GitHub-URL, kommasepariert
# Formate: casaos:URL  oder  umbrel:URL  (bare URL = casaos-Typ)
# Beispiel: umbrel:https://raw.githubusercontent.com/WaR10ck-2025/openclaw-umbrel-apps/main
CUSTOM_STORES=

# Legacy (backward-compat, ohne Typ-Präfix = casaos)
CASAOS_CUSTOM_STORES=

# Bridge-Integration in CasaOS App Store
# URL unter der die Bridge von CasaOS aus erreichbar ist
BRIDGE_URL=http://192.168.10.141:8200
# LXC-ID in der CasaOS läuft (für automatische Store-Registrierung)
BRIDGE_LXC_ID=120
