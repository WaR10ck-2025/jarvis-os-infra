# backup-credentials — SMB-Zugangsdaten für Netzwerkfreigabe (Beispiel)
# ══════════════════════════════════════════════════════════════════════
#
# WICHTIG: Diese Datei ist NUR ein Template.
# Die echte Credentials-Datei gehört nach: /etc/backup-credentials
# Mit: chmod 600 /etc/backup-credentials (root-only lesbar)
# NICHT ins git-Repo!
#
# ── Format ───────────────────────────────────────────────────────────────────
#   (für mount.cifs / CIFS-Mounts, keine Leerzeichen um das =)

username=proxmox-backup
password=DEIN_NAS_PASSWORT
domain=WORKGROUP

# ── Einrichten ────────────────────────────────────────────────────────────────
#   sudo cp secrets/backup-credentials.example /etc/backup-credentials
#   sudo nano /etc/backup-credentials      # Echte Werte eintragen
#   sudo chmod 600 /etc/backup-credentials
#   sudo chown root:root /etc/backup-credentials
#
# ── Verwendung in backup-vzdump.sh / backup-config.sh ───────────────────────
#   mount -t cifs "//${BACKUP_NETWORK_HOST}/${BACKUP_NETWORK_SHARE}" \
#     "${BACKUP_NETWORK_MOUNT}" \
#     -o "credentials=/etc/backup-credentials,uid=0,gid=0,vers=3.0"
#
# ── NFS (kein Passwort nötig) ────────────────────────────────────────────────
#   Für NFS wird diese Datei nicht benötigt.
#   NFS-Mount erfolgt via:
#   mount -t nfs "${BACKUP_NETWORK_HOST}:/${BACKUP_NETWORK_SHARE}" "${BACKUP_NETWORK_MOUNT}"
#   NFS-Zugriff wird über /etc/exports auf dem NAS gesteuert (IP-basiert).
#
# ── Synology NAS Setup ───────────────────────────────────────────────────────
#   1. Freigegebene Ordner → "proxmox-backup" erstellen
#   2. Benutzer → "proxmox-backup" anlegen, Zugriff auf Ordner gewähren
#   3. Systemsteuerung → Dateidienste → SMB aktivieren
#   4. backup-targets.conf: BACKUP_NETWORK_HOST=192.168.10.x
#
# ── TrueNAS Setup ────────────────────────────────────────────────────────────
#   1. Storage → Datasets → "proxmox-backup" Dataset anlegen
#   2. Shares → Windows (SMB) → Share hinzufügen
#   3. Credentials → Local Users → "proxmox-backup" anlegen
