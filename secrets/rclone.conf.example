# rclone.conf — Backblaze B2 Konfiguration (Beispiel)
# ══════════════════════════════════════════════════════
#
# WICHTIG: Diese Datei ist NUR ein Template.
# Die echte Konfiguration gehört nach: /etc/rclone.conf (chmod 600)
# NICHT ins git-Repo!
#
# ── Schritt 1: Backblaze B2 Account erstellen ────────────────────────────────
#   https://www.backblaze.com/b2/cloud-storage.html
#   → Bucket anlegen: "jarvis-appdata" (Private)
#   → Application Key erstellen mit Bucket-Zugriff
#
# ── Schritt 2: rclone installieren ──────────────────────────────────────────
#   (wird von install-backup-deps.sh automatisch erledigt)
#   curl https://rclone.org/install.sh | sudo bash
#
# ── Schritt 3: Konfiguration anlegen ─────────────────────────────────────────
#   Entweder manuell (Template unten anpassen) oder interaktiv:
#   rclone config
#
# ── Konfiguration ────────────────────────────────────────────────────────────

# Basis B2-Remote (ohne Verschlüsselung):
[b2-jarvis]
type = b2
account = YOUR_B2_ACCOUNT_ID
key = YOUR_B2_APPLICATION_KEY

# Verschlüsselter Layer über B2 (EMPFOHLEN — Client-seitig verschlüsselt):
[b2-jarvis-crypt]
type = crypt
remote = b2-jarvis:jarvis-appdata
filename_encryption = standard
directory_name_encryption = true
password = RCLONE_CRYPT_PASSWORD          # rclone obscure DEIN_PASSWORT
password2 = RCLONE_CRYPT_SALT             # rclone obscure DEIN_SALT

# ── Passwörter verschlüsseln (rclone obscure) ────────────────────────────────
#   rclone obscure "MeinGeheimesPasswort"
#   → Ausgabe: AQAAGxxxxxxxxxxxxxxxxxxxxxxxxxx
#   Diesen Wert als `password` eintragen.
#
# ── Test ────────────────────────────────────────────────────────────────────
#   rclone lsd b2-jarvis-crypt:         # Verzeichnisse auflisten
#   rclone copy /tmp/test.txt b2-jarvis-crypt:test/
#   rclone ls b2-jarvis-crypt:test/

# ── In backup.conf aktivieren ────────────────────────────────────────────────
#   B2_ENABLED=true
#   B2_RCLONE_REMOTE="b2-jarvis-crypt"
